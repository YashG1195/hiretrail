# ─────────────────────────────────────────────
# HireTrail — Environment Variables Template
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hiretrail

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (use long, random strings in production)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# File Storage (Phase 4)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# AWS S3 (Phase 4 — swap from local disk)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET_NAME=hiretrail-uploads

# Email — Nodemailer (Phase 6)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="HireTrail <no-reply@hiretrail.app>"

# Google OAuth (Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
